/**
 * @brief Helper: read LEDpos from PROGMEM (used by LEDpos custom patterns).
 */
LEDpos readLEDposFromPROGMEM(const LEDpos *ledPointList, int index) {
  LEDpos result;
  result.pos.radial = pgm_read_word(&(ledPointList[index].pos.radial));
  result.pos.angular = pgm_read_word(&(ledPointList[index].pos.angular));
  result.type = pgm_read_byte(&(ledPointList[index].type));
  result.color.r = pgm_read_byte(&(ledPointList[index].color.r));
  result.color.g = pgm_read_byte(&(ledPointList[index].color.g));
  result.color.b = pgm_read_byte(&(ledPointList[index].color.b));
  return result;
}
#endif

#if USE_LED_CIRCLE
/**
 * @brief Sets LED at specified r,theta position with explicit RGB color
 * 
 * @param r Radial position (0-1000)
 * @param theta Angular position in degrees*10 (0-3599)
 * @param red Red component (0-255)
 * @param green Green component (0-255)
 * @param blue Blue component (0-255)
 */
void setLedAtPosition(int r, int theta, uint8_t red, uint8_t green, uint8_t blue) {
  theta = normalizeAngleTenths(theta);
  int ledNumber = get_led_number(r, theta);
  
  if (ledNumber >= 0 && ledNumber < NUM_CIRCULAR_LEDS) {
    circularLeds[ledNumber] = CRGB(red, green, blue);
    lastCircularLedColorR = red;
    lastCircularLedColorG = green;
    lastCircularLedColorB = blue;
  }
}

/**
 * @brief Clears all circular LEDs and re-lights the current gantry position with the last color.
 * Call after theta offset changes so the user sees the current point at the new offset.
 */
void clearCircularLedsAndRelightCurrentPosition(void) {
  for (int i = 0; i < NUM_CIRCULAR_LEDS; i++) {
    circularLeds[i] = CRGB::Black;
  }
  int r = (int)((float)currentPositions.radial * (1000.0 / MAX_R_STEPS) / IMAGE_SCALE_FACTOR);
  int theta = motorStepsToPatternThetaTenths(currentPositions.angular);
  setLedAtPosition(r, theta, lastCircularLedColorR, lastCircularLedColorG, lastCircularLedColorB);
  fastLedShowCircularImmediate();
}

#endif

#if ENABLE_CALIBRATION
/** Pattern space: center -> (1000,0) -> center; stepped with the same drawLine/drawPictureStep path as any picture. */
static const Positions ledCalPoints[] PROGMEM = {
  {0, 0}, {1000, 0}, {0, 0}
};
#endif

/**
 * HACK BY ORION (AKA: Magicaldroid)
 *
 * @brief Generates the next target position to follow the points within pointList
 *
 * @param pointList An array of all the points in the pattern stored in a Positions struct.
 * @param current The current position of the gantry, represented as a Positions struct.
 * @param nodes Total number of points in the pattern
 * @param restartPattern Flag to restart the pattern (clears LEDs)
 * 
 * @return Positions The next target position for the motion controller, represented as a Positions struct.
 * 
 */
Positions drawPictureStep(const Positions *pointList, int nodes, Positions current, bool restartPattern = false, bool ledCalibrationPath = false)
{
  Positions target;
  static int start = 0;
  static int end = 1;
  static int previousStart = 0;  //Track previous start value to detect cycle completion
  static bool changePoints = true;
  static bool calibrationDone = false;  // PAUSE_AFTER_START: true after first segment completion this run
  static Positions readStart;
  static Positions readEnd;
#if USE_LED_CIRCLE
  static int currentColorIndex = 0;  //Track which color in the cycle we're using
  static bool colorInitialized = false;  //Track if color has been initialized
#endif
  
  uint16_t readValueR;
  uint16_t readValueA;

  if (restartPattern) {
    pausedAfterFirstPoint = false;
    calibrationDone = false;
    start = 0;
    end = 1;
    changePoints = true;
    readStart = {0, 0};
    readEnd.radial = pgm_read_word(&(pointList[0].radial));
    readEnd.angular = pgm_read_word(&(pointList[0].angular));
  }

  if (changePoints) {
    readValueR = pgm_read_word(&(pointList[end].radial));
    readValueA = pgm_read_word(&(pointList[end].angular));
    readStart = readEnd;
    readEnd = {readValueR, readValueA};
    changePoints = false;
  }

  Positions startPoint = { 
    (int)(readStart.radial * (float)MAX_R_STEPS/1000 * IMAGE_SCALE_FACTOR),
    patternAngularToMotorSteps((int)readStart.angular, !ledCalibrationPath)
  };
  Positions endPoint = { 
    (int)(readEnd.radial * (float)MAX_R_STEPS/1000 * IMAGE_SCALE_FACTOR),
    patternAngularToMotorSteps((int)readEnd.angular, !ledCalibrationPath)
  };

  target = drawLine(startPoint, endPoint, current, 100, restartPattern);
#if USE_LED_CIRCLE
  //Clear all circular LEDs and reset to white when a new pattern is selected
  if (restartPattern) {
    clearLedCircleOnRestart(currentColorIndex, colorInitialized);
  }

  //Update circular LED display based on target position
  updateLedCircleFromTarget(target, currentColorIndex, colorInitialized);
#endif

#if PAUSE_AFTER_START
  // Pause only when marble has physically arrived at the first coordinate (current position at startPoint)
  if (!ledCalibrationPath) {
    if (start == 0 && !calibrationDone && current.radial == startPoint.radial && current.angular == startPoint.angular) {
      calibrationDone = true;
      runPattern = false;
      pausedAfterFirstPoint = true;
      return target;
    }
  }
#endif

  if ((target.angular == endPoint.angular) && (target.radial == endPoint.radial)) {
    changePoints = true;
    start++;
    end++;
    
    // Completed when we've just reached the last point in the sequence (before looping back)
    bool patternCompleted = (end == nodes);
    
    start = start % nodes;
    end = end % nodes;
    
#if USE_LED_CIRCLE
    //Cycle to next color when pattern completes a full pass (don't clear - trace over existing pattern)
    if (patternCompleted && !ledCalibrationPath) {
      if (colorInitialized) {
        currentColorIndex = (currentColorIndex + 1) % NUM_IMAGE_COLORS;  //Cycle to next color
      } else {
        currentColorIndex = 0;  //Start with first color (White) on first run
        colorInitialized = true;
      }
      //Don't clear LEDs - let it trace over the existing pattern with the new color
    }
#endif

    // Update previous start value regardless of LED circle usage (needed for completion detection)
    previousStart = start;

#if !PATTERN_LOOP_ON_COMPLETE
    // If looping is disabled, stop pattern and return to selection mode when complete
    if (patternCompleted) {
      runPattern = false;
#if ENABLE_CALIBRATION
      if (ledCalibrationPath) {
        pausedForCalibration = true;
        refreshCalibrationPauseLed();
      } else
#endif
      {
        patternSwitched = true;
      }
    }
#endif
  }
  return target;
}

#if ENABLE_CALIBRATION
Positions drawPictureStepLedCalibration(Positions current, bool restartPattern) {
  return drawPictureStep(ledCalPoints, 3, current, restartPattern, true);
}
#endif

#if ENABLE_CUSTOM_PATTERN && ENABLE_COLORED_PATTERN_SUPPORT
/**
 * @brief Overloaded version of drawPictureStep that accepts LEDpos array
 * 
 * Reuses the same logic as drawPictureStep for type 0 (marble) points,
 * but adds support for type 1 (fill) and type 2 (detail) points with explicit RGB colors.
 * Circular LED updates only when USE_LED_CIRCLE; marble motion follows type 0 segments whenever this overload is compiled (ENABLE_COLORED_PATTERN_SUPPORT).
 * 
 * @param ledPointList An array of LEDpos structs in PROGMEM
 * @param nodes Total number of points in the pattern
 * @param current The current position of the gantry
 * @param restartPattern Flag to restart the pattern
 * @return Positions The next target position
 */
Positions drawPictureStep(const LEDpos *ledPointList, int nodes, Positions current, bool restartPattern = false)
{
  Positions target;
  static int start = 0;
  static int end = 1;
  static int previousStart = 0;
  static bool changePoints = true;
  static Positions readStart = {0,0};
  static Positions readEnd = {0,0};
  static uint8_t currentR = 255, currentG = 255, currentB = 255; // Default to white
  static Positions lastMarblePosition = {0, 0};
  
  uint16_t readValueR;
  uint16_t readValueA;

  static bool calibrationDone = false;  // PAUSE_AFTER_START: true after first segment completion this run
  if (restartPattern) {
    start = 0;
    end = 1;
    previousStart = 0;
    changePoints = true;
    readStart = {0,0};
    lastMarblePosition = current;
    pausedAfterFirstPoint = false;
    calibrationDone = false;
#if USE_LED_CIRCLE
    for (int i = 0; i < NUM_CIRCULAR_LEDS; i++) {
      circularLeds[i] = CRGB::Black;
    }
    invalidateDeferredFastLedHash();
#endif
  }

  if (changePoints) {
    LEDpos startLED = readLEDposFromPROGMEM(ledPointList, start);
    LEDpos endLED = readLEDposFromPROGMEM(ledPointList, end);
    
    readValueR = startLED.pos.radial;
    readValueA = startLED.pos.angular;
    readStart = {readValueR, readValueA};
    
    readValueR = endLED.pos.radial;
    readValueA = endLED.pos.angular;
    readEnd = {readValueR, readValueA};
    
    // Extract RGB color from start point
    currentR = startLED.color.r;
    currentG = startLED.color.g;
    currentB = startLED.color.b;
    
    changePoints = false;
  }

  Positions startPoint = { (int)(readStart.radial * (float)MAX_R_STEPS/1000 * IMAGE_SCALE_FACTOR), patternAngularToMotorSteps((int)readStart.angular) };
  Positions endPoint = { (int)(readEnd.radial * (float)MAX_R_STEPS/1000 * IMAGE_SCALE_FACTOR), patternAngularToMotorSteps((int)readEnd.angular) };

  // Check END point type: if end is type 1 or 2, set LED at end position only (do not move marble)
  LEDpos endLED = readLEDposFromPROGMEM(ledPointList, end);
  if (endLED.type == 1 || endLED.type == 2) {
#if PAUSE_AFTER_START
    // Pause when we're about to process the first point (index 0) as a fill/detail
    if (end == 0 && !calibrationDone) {
      runPattern = false;
      pausedAfterFirstPoint = true;
      calibrationDone = true;
      return lastMarblePosition;
    }
#endif
#if USE_LED_CIRCLE
    setLedAtPosition(endLED.pos.radial, endLED.pos.angular, endLED.color.r, endLED.color.g, endLED.color.b);
#endif
    unsigned long delayMs = (endLED.type == 1) ? FILL_POINT_DELAY_MS : DETAIL_POINT_DELAY_MS;
    unsigned long startTime = millis();
    while ((millis() - startTime) < delayMs && runPattern) {
      button.tick();
      delay(1);
    }
    // Advance to next segment; completed when we've just processed the last point (index nodes-1)
    bool patternCompleted = (end == (nodes - 1));
    start++;
    if (start >= nodes) start = 0;
    end = (start + 1) % nodes;
    previousStart = start;
    changePoints = true;
#if !PATTERN_LOOP_ON_COMPLETE
    if (patternCompleted) {
      runPattern = false;
      patternSwitched = true;
    }
#endif
    return lastMarblePosition;
  }

  // End is type 0 (marble point): move marble from actual position to end.
  // If start point was type 1/2 we never moved the marble there — use last type-0 position.
  LEDpos startLED = readLEDposFromPROGMEM(ledPointList, start);
  Positions lineStart = (startLED.type == 0) ? startPoint : lastMarblePosition;
  target = drawLine(lineStart, endPoint, current, 100);

#if USE_LED_CIRCLE
  // Update LED with explicit RGB color from LEDpos (not color cycle)
  int r = (int)((float)target.radial * (1000.0 / MAX_R_STEPS) / IMAGE_SCALE_FACTOR);
  int theta = motorStepsToPatternThetaTenths(target.angular);
  setLedAtPosition(r, theta, currentR, currentG, currentB);
#endif

#if PAUSE_AFTER_START
  // Pause only when marble has physically arrived at the first coordinate (current position at startPoint)
  if (start == 0 && !calibrationDone && current.radial == startPoint.radial && current.angular == startPoint.angular) {
    calibrationDone = true;
    runPattern = false;
    pausedAfterFirstPoint = true;
    return target;
  }
#endif

  if ((target.angular == endPoint.angular) && (target.radial == endPoint.radial)) {
    changePoints = true;
    start++;
    end++;
    
    // Completed when we've just reached the last point in the sequence (before looping back)
    bool patternCompleted = (end == nodes);
    
    start = start % nodes;
    end = end % nodes;
    previousStart = start;
    
    // Update last marble position for next segment
    lastMarblePosition = target;

#if !PATTERN_LOOP_ON_COMPLETE
    // If looping is disabled, stop pattern and return to selection mode when complete
    if (patternCompleted) {
      runPattern = false;
      patternSwitched = true;
    }
#endif
  }
  return target;
}
#endif

