LedDisplay display;

static uint32_t hashPixelBlob(const uint8_t *p, uint16_t n) {
  uint32_t h = 2166136261U;
  while (n--) {
    h ^= *p++;
    h *= 16777619U;
  }
  return h;
}

static uint32_t s_deferredStripHash;
static bool s_haveDeferredStripHash = false;

/** Call after clearing circularLeds[] (or similar) so the next deferred push is not skipped when RAM hash matched stale state. */
static void invalidateDeferredFastLedHash(void) {
  s_haveDeferredStripHash = false;
}

/** After each move while runPattern: FastLED.show() only if bar (+ ring) pixel buffers changed vs last push. */
static void maybeFastLedShowAfterMotion(uint32_t barHash) {
  uint32_t h = barHash;
#if USE_LED_CIRCLE
  uint32_t hCirc = hashPixelBlob(reinterpret_cast<const uint8_t *>(circularLeds), (uint16_t)sizeof(circularLeds));
  h ^= (hCirc + 0x9e3779b9U + (barHash << 6) + (barHash >> 2));
#endif
  if (!s_haveDeferredStripHash || h != s_deferredStripHash) {
    FastLED.show();
    s_deferredStripHash = h;
    s_haveDeferredStripHash = true;
  }
}

