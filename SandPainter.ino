//=== POSITIONS STRUCT - Used by pattern coordinate data below ===
//Struct used for storing positions of the axes in polar coordinates (radial, angular)
struct Positions {
  short int radial;                     // the units for these values are motor steps; in pattern_Picture and pattern_Remote the units are scaled from 0-1000
  short int angular;                    // in pattern_Picture and pattern_Remote the units are degrees * 10
};

//=== PATTERN COLOR STRUCT - Used inside LEDpos for color (named to avoid conflict with library RGB macros) ===
struct PatternColor {
  unsigned char r, g, b;                // RGB color values (0-255)
};

//=== LEDPOS STRUCT - Used for LED-enhanced patterns with color and point type ===
//Struct used for storing positions with LED color information and point type
//Format: {{r,theta}, type, {r,g,b}}
struct LEDpos {
  Positions pos;                         // nested Positions struct for r,theta coordinates
  unsigned char type;                   // 0=marble point, 1=fill point, 2=detail point
  PatternColor color;                   // RGB color values (0-255)
};

